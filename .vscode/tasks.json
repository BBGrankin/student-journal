{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build group manager",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++20",
                "-Wall",
                "-Wextra",
                "-pedantic",
                "-g",
                "main.cpp",
                "source/Student.cpp",
                "source/Group.cpp",
                "source/Commands.cpp",
                "-Iinclude",
                "-o",
                "group_manager.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
        }
    ]
}